{
  "expo": {
    "name": "Freedom",
    "slug": "school-management-mobile",
    "scheme": "freedom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/frfr.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/frfr.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.schoolmanagementmobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/frfr.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.example.schoolmanagementmobile",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/frfr.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d41d9104-5bc2-4794-8c8a-dbeed7006530"
      }
    }
  }
}
